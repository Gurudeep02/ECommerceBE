pipeline {
agent any

tools {
    maven 'Maven3'
    jdk 'JDK21'
}

environment {
    DOCKER_USER = 'gurudeep02'
}

stages {

    stage('Checkout') {
        steps {
            checkout scm
        }
    }

    stage('Detect Changed Services') {
        steps {
            script {

                def changedFiles = sh(
                    script: 'git diff --name-only HEAD~1 HEAD || true',
                    returnStdout: true
                ).trim()

                echo "Changed Files:"
                echo changedFiles

                def services = []

                if (changedFiles.contains('api-gateway/')) {
                    services.add('api-gateway')
                }

                if (changedFiles.contains('order-service/')) {
                    services.add('order-service')
                }

                if (changedFiles.contains('product-service/')) {
                    services.add('product-service')
                }

                if (changedFiles.contains('inventory-service/')) {
                    services.add('inventory-service')
                }

                if (changedFiles.contains('notification-service/')) {
                    services.add('notification-service')
                }

                env.CHANGED_SERVICES = services.join(',')

                if (services.isEmpty()) {
                    echo "No service changes detected."
                } else {
                    echo "Services to build: ${env.CHANGED_SERVICES}"
                }
            }
        }
    }

    stage('Build & Package') {
        when {
            expression {
                env.CHANGED_SERVICES?.trim()
            }
        }

        steps {
            script {

                def services = env.CHANGED_SERVICES.split(',')

                for (service in services) {

                    if (service.trim()) {

                        dir(service.trim()) {

                            sh 'mvn clean package -DskipTests'

                            sh """
                                docker build -t ${DOCKER_USER}/${service}:latest .
                            """
                        }
                    }
                }
            }
        }
    }

    stage('Docker Login') {
        when {
            expression {
                env.CHANGED_SERVICES?.trim()
            }
        }

        steps {

            withCredentials([
                usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USERNAME',
                    passwordVariable: 'DOCKER_PASSWORD'
                )
            ]) {

                sh '''
                    echo "$DOCKER_PASSWORD" | docker login -u "$DOCKER_USERNAME" --password-stdin
                '''
            }
        }
    }

    stage('Push Images') {
        when {
            expression {
                env.CHANGED_SERVICES?.trim()
            }
        }

        steps {

            script {

                def services = env.CHANGED_SERVICES.split(',')

                for (service in services) {

                    if (service.trim()) {

                        sh """
                            docker push ${DOCKER_USER}/${service}:latest
                        """
                    }
                }
            }
        }
    }

    stage('Restart Containers') {
        when {
            expression {
                env.CHANGED_SERVICES?.trim()
            }
        }

        steps {

            script {

                def services = env.CHANGED_SERVICES.split(',')

                for (service in services) {

                    if (service.trim()) {

                        sh """
                            docker compose stop ${service}
                            docker compose rm -f ${service}
                            docker compose up -d ${service}
                        """
                    }
                }
            }
        }
    }
}

post {

    success {
        echo 'Pipeline completed successfully'
    }

    failure {
        echo 'Pipeline failed'
    }
}
}