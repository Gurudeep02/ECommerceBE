pipeline {
agent any

tools {
    maven 'Maven3'
    jdk 'JDK21'
}

environment {
    DOCKER_USER = 'gurudeep02'
    DOCKER_BUILDKIT = '0'
}

stages {

    stage('Checkout') {
        steps {
            checkout scm

            sh '''
                git --version
                docker --version
            '''
        }
    }

    stage('Detect Changed Services') {
        steps {
            script {

                def changedFiles = sh(
                    script: '''
                        git diff --name-only HEAD~1 HEAD 2>/dev/null || git ls-tree -r HEAD --name-only
                    ''',
                    returnStdout: true
                ).trim()

                echo "=============================="
                echo "Changed Files:"
                echo changedFiles
                echo "=============================="

                def services = []

                if (changedFiles.contains('Product/')) {
                    services.add('product-service')
                }

                if (changedFiles.contains('Orders/')) {
                    services.add('order-service')
                }

                if (changedFiles.contains('Notification/')) {
                    services.add('notification-service')
                }

                if (changedFiles.contains('Authentication/')) {
                    services.add('authentication-service')
                }

                if (changedFiles.contains('Analytics/')) {
                    services.add('analytics-service')
                }

                env.CHANGED_SERVICES = services.unique().join(',')

                echo "Detected Services: ${services}"
                echo "CHANGED_SERVICES: ${env.CHANGED_SERVICES}"

                if (services.isEmpty()) {
                    echo "No service changes detected."
                }
            }
        }
    }

    stage('Build & Package') {
        when {
            expression {
                return env.CHANGED_SERVICES?.trim()
            }
        }

        steps {
            script {

                def folderMap = [
                    'product-service'        : 'Product',
                    'order-service'          : 'Orders',
                    'notification-service'   : 'Notification',
                    'authentication-service' : 'Authentication',
                    'analytics-service'      : 'Analytics'
                ]

                def services = env.CHANGED_SERVICES.split(',')

                services.each { service ->

                    if (service.trim()) {

                        def folder = folderMap[service.trim()]

                        echo "Building ${service} from ${folder}"

                        dir(folder) {

                            sh 'mvn clean package -DskipTests'

                            sh """
                                export DOCKER_BUILDKIT=0

                                docker build \
                                --no-cache \
                                -t ${DOCKER_USER}/${service}:latest .
                            """

                            sh """
                                docker image inspect \
                                ${DOCKER_USER}/${service}:latest
                            """
                        }
                    }
                }
            }
        }
    }

    stage('Docker Login') {
        when {
            expression {
                return env.CHANGED_SERVICES?.trim()
            }
        }

        steps {

            withCredentials([
                usernamePassword(
                    credentialsId: 'dockerhub-creds',
                    usernameVariable: 'DOCKER_USERNAME',
                    passwordVariable: 'DOCKER_PASSWORD'
                )
            ]) {

                sh '''
                    echo "$DOCKER_PASSWORD" | docker login \
                    -u "$DOCKER_USERNAME" \
                    --password-stdin
                '''
            }
        }
    }

    stage('Push Images') {
        when {
            expression {
                return env.CHANGED_SERVICES?.trim()
            }
        }

        steps {
            script {

                def services = env.CHANGED_SERVICES.split(',')

                services.each { service ->

                    if (service.trim()) {

                        echo "Pushing ${service}"

                        retry(3) {

                            sh """
                                docker image inspect \
                                ${DOCKER_USER}/${service}:latest

                                docker push \
                                ${DOCKER_USER}/${service}:latest
                            """
                        }
                    }
                }
            }
        }
    }

    stage('Restart Containers') {
        when {
            expression {
                return env.CHANGED_SERVICES?.trim()
            }
        }

        steps {
            script {

                def services = env.CHANGED_SERVICES.split(',')

                sh '''
                    pwd
                    ls -la
                '''

                services.each { service ->

                    if (service.trim()) {

                        echo "Restarting ${service}"

                        sh """
                            docker compose stop ${service} || true
                            docker compose rm -f ${service} || true
                            docker compose pull ${service} || true
                            docker compose up -d ${service}
                        """
                    }
                }
            }
        }
    }
}

post {

    success {
        echo 'Pipeline completed successfully'
    }

    failure {
        echo 'Pipeline failed'
    }

    always {
        cleanWs()
    }
}

}